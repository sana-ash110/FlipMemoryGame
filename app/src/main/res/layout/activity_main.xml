<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_dark"
    android:padding="32dp">

    <!-- Game title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🃏 FLIP MEMORY"
        android:textColor="@color/accent_gold"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Your Level"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:layout_marginBottom="48dp"/>

    <!-- Beginner button -->
    <Button
        android:id="@+id/btnBeginner"
        android:layout_width="260dp"
        android:layout_height="64dp"
        android:text="🌱  BEGINNER   4×4"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/level_beginner"
        android:layout_marginBottom="16dp"/>

    <!-- Intermediate button -->
    <Button
        android:id="@+id/btnIntermediate"
        android:layout_width="260dp"
        android:layout_height="64dp"
        android:text="🔥  INTERMEDIATE  6×6"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/level_intermediate"
        android:layout_marginBottom="16dp"/>

    <!-- Advanced button -->
    <Button
        android:id="@+id/btnAdvanced"
        android:layout_width="260dp"
        android:layout_height="64dp"
        android:text="💀  ADVANCED   8×8"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/level_advanced"
        android:layout_marginBottom="32dp"/>

    <!-- Divider -->
    <View
        android:layout_width="200dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="32dp"/>

    <!-- High scores -->
    <TextView
        android:id="@+id/tvHighScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏆 High Scores\nLoading…"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingExtra="6dp"/>

</LinearLayout>